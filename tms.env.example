# Copy this file to tms.env.local and fill in real values — tms.env.local is
# gitignored and is what 901_set-env.ps1 actually reads.
#
# Format: KEY=VALUE, one per line. Blank lines and lines starting with # are
# ignored. Values may be wrapped in quotes if they contain leading/trailing
# spaces. These become process (and optionally user-level) environment
# variables for services started via 001_run-services.ps1 / 002_run-published.ps1.
#
# .NET config uses "__" as the nesting delimiter (e.g. Redis__Password maps
# to config section Redis:Password) — keep that convention for any key your
# services read from IConfiguration.

DefaultKey=
Identity__Key=

Redis__ConnectionString=localhost:6379
Redis__Password=

KafkaFlow__BootstrapServers=localhost:9092

RabbitMq__HostName=localhost
RabbitMq__Port=5672
RabbitMq__UserName=guest
RabbitMq__Password=guest

OpenTelemetry__OtlpEndpoint=http://localhost:4318
OpenTelemetry__Key=

# Add any other secrets/URLs your services expect, e.g. cross-service URLs
# (match the ports you set in tms.config.json's services[]):
# FleetService__Url=http://localhost:10000
# ThirdParty__ApiKey=
